# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed browser origins (frontend URLs)
CORS_ORIGINS=http://localhost:5173

# ─── Database (PostgreSQL) ────────────────────────────────
# Runtime (pooled) connection. On Neon use the *-pooler* host with ?pgbouncer=true.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rawaqan?schema=public"
# Direct (non-pooled) connection for Prisma migrations. On Neon use the direct
# host (no -pooler). Locally/Docker it's the same as DATABASE_URL.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/rawaqan?schema=public"

# ─── Auth (JWT) ───────────────────────────────────────────
# Use long random strings in production: `openssl rand -base64 48`
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
# Brute-force lockout: lock an account after N failed logins for M minutes.
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# ─── Cloudinary (image storage) ───────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=rawaqan

# ─── Seed admin (first run only) ──────────────────────────
SEED_ADMIN_EMAIL=admin@rawaqan.local
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_NAME=Rawaqan Admin

# ─── Public site URL (for QR generation) ──────────────────
PUBLIC_SITE_URL=http://localhost:5173
